<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Acme Intranet Directory</title>
  <style>
    :root {
      --bg: #f5f7fb;
      --card: #ffffff;
      --line: #e5e7eb;
      --text: #111827;
      --muted: #6b7280;
      --accent: #2563eb;
      --accent-soft: #dbeafe;
      --good: #059669;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, Arial, sans-serif;
      background: linear-gradient(180deg, #eef4ff 0%, var(--bg) 180px, var(--bg) 100%);
      color: var(--text);
    }
    .wrap { max-width: 1240px; margin: 0 auto; padding: 32px 20px 48px; }
    .hero { display: grid; grid-template-columns: 1.4fr 0.9fr; gap: 20px; margin-bottom: 20px; }
    .card { background: var(--card); border: 1px solid var(--line); border-radius: 18px; box-shadow: var(--shadow); }
    .hero-main { padding: 28px; }
    .eyebrow {
      display: inline-block; padding: 7px 10px; border-radius: 999px; background: var(--accent-soft);
      color: var(--accent); font-size: 12px; font-weight: 700; letter-spacing: .02em; margin-bottom: 14px;
    }
    .hero-main h1 { margin: 0 0 10px; font-size: 34px; }
    .hero-main p { margin: 0; color: var(--muted); line-height: 1.65; }
    .chips { margin-top: 16px; display: flex; gap: 10px; flex-wrap: wrap; }
    .chip { padding: 8px 12px; border-radius: 999px; background: #f8fafc; border: 1px solid var(--line); color: var(--text); font-size: 13px; font-weight: 600; }
    .hero-side { padding: 22px; }
    .hero-side h2 { margin: 0 0 14px; font-size: 18px; }
    .stat { display: flex; justify-content: space-between; padding: 12px 0; border-top: 1px solid var(--line); font-size: 14px; }
    .stat:first-of-type { border-top: 0; }
    .good { color: var(--good); font-weight: 600; }
    .grid { display: grid; grid-template-columns: 1.35fr 0.75fr; gap: 20px; }
    .search-card, .side-card { padding: 22px; }
    .section-title { margin: 0 0 14px; font-size: 18px; }
    .section-sub { margin: 0 0 18px; color: var(--muted); font-size: 14px; }
    .controls { display: grid; grid-template-columns: 160px 160px 1fr 1fr; gap: 12px; margin-bottom: 12px; }
    form { display: grid; grid-template-columns: 1fr auto; gap: 12px; margin-bottom: 18px; }
    input, select, button {
      width: 100%; padding: 12px 14px; border-radius: 12px; border: 1px solid var(--line); font-size: 14px;
      background: #fff;
    }
    button { background: var(--accent); color: white; border: 0; font-weight: 700; cursor: pointer; }
    button:hover { filter: brightness(0.97); }
    .helper {
      display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
      color: var(--muted); font-size: 13px; margin-bottom: 16px;
    }
    .muted-code {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace; background: #f8fafc; padding: 2px 6px;
      border-radius: 6px; border: 1px solid var(--line);
    }
    .results { border-top: 1px solid var(--line); padding-top: 16px; }
    .result-count { font-size: 14px; color: var(--muted); margin-bottom: 12px; }
    .result-item {
      display: grid; grid-template-columns: 1fr auto; gap: 14px; padding: 16px; border: 1px solid var(--line);
      border-radius: 16px; margin-bottom: 12px; background: #fbfdff;
    }
    .name { font-weight: 800; font-size: 16px; }
    .subline { color: var(--muted); font-size: 13px; margin-top: 3px; }
    .title { margin-top: 8px; font-size: 14px; font-weight: 600; }
    .meta-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; }
    .meta-pill {
      background: #f8fafc; border: 1px solid var(--line); color: var(--muted); padding: 6px 10px;
      border-radius: 999px; font-size: 12px; font-weight: 700;
    }
    .role {
      align-self: start; background: #eef2ff; color: #4338ca; padding: 6px 10px; border-radius: 999px;
      font-size: 12px; font-weight: 700;
    }
    .mini-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 18px; }
    .mini-card { border: 1px solid var(--line); border-radius: 14px; padding: 14px; background: #fbfdff; }
    .mini-card .label { color: var(--muted); font-size: 12px; }
    .mini-card .value { font-size: 20px; font-weight: 800; margin-top: 6px; }
    .list { margin: 0; padding: 0; list-style: none; }
    .list li { border-top: 1px solid var(--line); padding: 12px 0; font-size: 14px; }
    .list li:first-child { border-top: 0; }
    .tiny { color: var(--muted); font-size: 12px; }
    .history-list { display: flex; flex-direction: column; gap: 10px; }
    .history-item {
      border: 1px solid var(--line); border-radius: 12px; padding: 10px 12px; background: #fbfdff;
      font-size: 13px; color: var(--muted);
    }
    .history-item strong { color: var(--text); }
    .clear-btn { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .card-actions { display: flex; gap: 8px; margin-top: 12px; }
    .secondary-btn { background: #f8fafc; color: var(--text); border: 1px solid var(--line); }
    .modal-backdrop {
      position: fixed; inset: 0; background: rgba(15, 23, 42, 0.45); display: none; align-items: center; justify-content: center;
      padding: 20px; z-index: 50;
    }
    .modal-backdrop.open { display: flex; }
    .modal {
      width: min(680px, 100%); background: white; border-radius: 18px; border: 1px solid var(--line); box-shadow: var(--shadow);
      overflow: hidden;
    }
    .modal-head { padding: 18px 20px; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; gap: 10px; }
    .modal-title { font-size: 20px; font-weight: 800; margin: 0; }
    .modal-sub { margin-top: 4px; color: var(--muted); font-size: 13px; }
    .icon-btn {
      border: 1px solid var(--line); background: white; border-radius: 10px; width: 40px; height: 40px; cursor: pointer;
      font-size: 18px;
    }
    .modal-body { padding: 20px; }
    .detail-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .detail-card { border: 1px solid var(--line); border-radius: 14px; padding: 14px; background: #fbfdff; }
    .detail-label { font-size: 12px; color: var(--muted); }
    .detail-value { margin-top: 6px; font-size: 15px; font-weight: 700; }
    @media (max-width: 900px) {
      .hero, .grid, .mini-grid, .detail-grid { grid-template-columns: 1fr; }
      form, .controls { grid-template-columns: 1fr; }
      .result-item { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="hero">
      <div class="card hero-main">
        <span class="eyebrow">INTERNAL USE ONLY</span>
        <h1>Acme Intranet Directory</h1>
        <p>
          Search the internal employee directory used by operations, HR, finance, security, and support teams.
          Public profile data is mirrored here for day-to-day coordination across regional offices.
        </p>
        <div class="chips">
          <span class="chip">Directory Sync: Online</span>
          <span class="chip">Search Scope: Staff Accounts</span>
          <span class="chip">Visibility: Public Profile Fields</span>
        </div>
      </div>
      <aside class="card hero-side">
        <h2>System status</h2>
        <div class="stat"><span>Directory health</span><span class="good">Operational</span></div>
        <div class="stat"><span>Last sync</span><span>2 minutes ago</span></div>
        <div class="stat"><span>Indexed accounts</span><span><%= employeeCount %></span></div>
        <div class="stat"><span>Active departments</span><span><%= departmentCount %></span></div>
        <div class="stat"><span>Office locations</span><span><%= locationCount %></span></div>
      </aside>
    </section>

    <section class="grid">
      <div class="card search-card">
        <h2 class="section-title">User search</h2>
        <p class="section-sub">Search by username or email to review employee profile cards and internal directory metadata.</p>

        <div class="mini-grid">
          <div class="mini-card">
            <div class="label">Indexed employees</div>
            <div class="value"><%= employeeCount %></div>
          </div>
          <div class="mini-card">
            <div class="label">Departments</div>
            <div class="value"><%= departmentCount %></div>
          </div>
          <div class="mini-card">
            <div class="label">Locations</div>
            <div class="value"><%= locationCount %></div>
          </div>
        </div>

        <div class="controls">
          <select id="field">
            <option value="username">username</option>
            <option value="email">email</option>
          </select>
          <select id="op">
            <option value="contains">contains</option>
            <option value="startsWith">startsWith</option>
            <option value="equals">equals</option>
          </select>
          <select id="department">
            <option value="">All departments</option>
            <% departments.forEach(function(dept) { %>
              <option value="<%= dept %>"><%= dept %></option>
            <% }) %>
          </select>
          <select id="location">
            <option value="">All locations</option>
            <% locations.forEach(function(loc) { %>
              <option value="<%= loc %>"><%= loc %></option>
            <% }) %>
          </select>
        </div>

        <form id="searchForm">
          <input id="value" type="text" placeholder="Search by username or email" value="ad" />
          <button type="submit">Search</button>
        </form>

        <div class="helper">
          <span>Example endpoint: <span class="muted-code">/api/users?field=username&amp;op=contains&amp;value=ad</span></span>
          <span>Returned cards show public profile fields only.</span>
        </div>

        <div class="results">
          <div class="result-count" id="resultCount">Try a search to view results.</div>
          <div id="resultList"></div>
        </div>
      </div>

      <aside class="card side-card">
        <h2 class="section-title">Recent staff activity</h2>
        <ul class="list">
          <li><strong>Operations</strong><br><span class="tiny">Regional directory refresh completed for Seoul and Incheon.</span></li>
          <li><strong>HR</strong><br><span class="tiny">Three new joiner accounts provisioned this week.</span></li>
          <li><strong>Support</strong><br><span class="tiny">Night-shift handoff roster synchronized successfully.</span></li>
          <li><strong>Security</strong><br><span class="tiny">Quarterly audit contact list verified for all departments.</span></li>
        </ul>

        <h2 class="section-title" style="margin-top: 20px;">Recent searches</h2>
        <div class="history-list" id="historyList">
          <div class="tiny">No recent searches yet.</div>
        </div>
        <div class="card-actions">
          <button type="button" class="clear-btn" id="clearHistoryBtn">Clear history</button>
        </div>
      </aside>
    </section>
  </div>

  <div class="modal-backdrop" id="modalBackdrop">
    <div class="modal">
      <div class="modal-head">
        <div>
          <h3 class="modal-title" id="modalTitle">Employee Details</h3>
          <div class="modal-sub" id="modalSub">Public profile summary</div>
        </div>
        <button class="icon-btn" id="closeModalBtn">×</button>
      </div>
      <div class="modal-body">
        <div class="detail-grid" id="modalDetails"></div>
      </div>
    </div>
  </div>

  <script>
    const searchForm = document.getElementById('searchForm');
    const fieldEl = document.getElementById('field');
    const opEl = document.getElementById('op');
    const departmentEl = document.getElementById('department');
    const locationEl = document.getElementById('location');
    const valueEl = document.getElementById('value');
    const resultCountEl = document.getElementById('resultCount');
    const resultListEl = document.getElementById('resultList');
    const historyListEl = document.getElementById('historyList');
    const clearHistoryBtn = document.getElementById('clearHistoryBtn');
    const modalBackdrop = document.getElementById('modalBackdrop');
    const closeModalBtn = document.getElementById('closeModalBtn');
    const modalTitle = document.getElementById('modalTitle');
    const modalSub = document.getElementById('modalSub');
    const modalDetails = document.getElementById('modalDetails');

    const HISTORY_KEY = 'acme-directory-search-history';

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function readHistory() {
      try {
        return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]');
      } catch {
        return [];
      }
    }

    function writeHistory(items) {
      localStorage.setItem(HISTORY_KEY, JSON.stringify(items.slice(0, 8)));
    }

    function renderHistory() {
      const items = readHistory();
      if (!items.length) {
        historyListEl.innerHTML = '<div class="tiny">No recent searches yet.</div>';
        return;
      }

      historyListEl.innerHTML = items.map((item) => `
        <div class="history-item">
          <strong>${escapeHtml(item.field)}</strong> ${escapeHtml(item.op)} <span class="muted-code">${escapeHtml(item.value || '(empty)')}</span><br>
          <span>${escapeHtml(item.department || 'All departments')} · ${escapeHtml(item.location || 'All locations')}</span>
        </div>
      `).join('');
    }

    function addHistory(entry) {
      const items = readHistory();
      const filtered = items.filter((item) => JSON.stringify(item) !== JSON.stringify(entry));
      filtered.unshift(entry);
      writeHistory(filtered);
      renderHistory();
    }

    function openModal(user) {
      modalTitle.textContent = user.full_name;
      modalSub.textContent = `@${user.username} · ${user.email}`;
      const pairs = [
        ['Employee ID', user.employee_id],
        ['Title', user.title],
        ['Department', user.department],
        ['Location', user.location],
        ['Extension', user.phone_ext],
        ['Role', user.role]
      ];
      modalDetails.innerHTML = pairs.map(([label, value]) => `
        <div class="detail-card">
          <div class="detail-label">${escapeHtml(label)}</div>
          <div class="detail-value">${escapeHtml(value)}</div>
        </div>
      `).join('');
      modalBackdrop.classList.add('open');
    }

    function closeModal() {
      modalBackdrop.classList.remove('open');
    }

    async function loadUser(username) {
      const res = await fetch(`/api/users/${encodeURIComponent(username)}`);
      if (!res.ok) return;
      const user = await res.json();
      openModal(user);
    }

    function renderResults(data) {
      resultCountEl.textContent = `Found ${data.total} matching account${data.total === 1 ? '' : 's'}.`;

      if (!data.items || data.items.length === 0) {
        resultListEl.innerHTML = '<div class="tiny">No matching public profiles were found.</div>';
        return;
      }

      resultListEl.innerHTML = data.items.map((user) => `
        <div class="result-item">
          <div>
            <div class="name">${escapeHtml(user.full_name)}</div>
            <div class="subline">@${escapeHtml(user.username)} · ${escapeHtml(user.email)}</div>
            <div class="title">${escapeHtml(user.title)}</div>
            <div class="meta-row">
              <span class="meta-pill">${escapeHtml(user.department)}</span>
              <span class="meta-pill">${escapeHtml(user.location)}</span>
              <span class="meta-pill">Ext. ${escapeHtml(user.phone_ext)}</span>
              <span class="meta-pill">${escapeHtml(user.employee_id)}</span>
            </div>
            <div class="card-actions">
              <button type="button" class="secondary-btn" data-username="${escapeHtml(user.username)}">View details</button>
            </div>
          </div>
          <div class="role">${escapeHtml(user.role)}</div>
        </div>
      `).join('');

      resultListEl.querySelectorAll('[data-username]').forEach((btn) => {
        btn.addEventListener('click', () => loadUser(btn.dataset.username));
      });
    }

    async function runSearch() {
      const field = fieldEl.value;
      const op = opEl.value;
      const value = valueEl.value;
      const department = departmentEl.value;
      const location = locationEl.value;
      const params = new URLSearchParams({ field, op, value });
      if (department) params.set('department', department);
      if (location) params.set('location', location);
      const res = await fetch(`/api/users?${params.toString()}`);
      const data = await res.json();
      renderResults(data);
      addHistory({ field, op, value, department, location });
    }

    searchForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      await runSearch();
    });

    clearHistoryBtn.addEventListener('click', () => {
      localStorage.removeItem(HISTORY_KEY);
      renderHistory();
    });

    closeModalBtn.addEventListener('click', closeModal);
    modalBackdrop.addEventListener('click', (e) => {
      if (e.target === modalBackdrop) closeModal();
    });

    renderHistory();
    runSearch();
  </script>
</body>
</html>
