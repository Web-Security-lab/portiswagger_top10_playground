datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int     @id @default(autoincrement())
  employee_id String  @unique
  username    String  @unique
  email       String  @unique
  full_name   String
  title       String
  department  String
  location    String
  phone_ext   String
  role        String
  reset_token String?
  secret_note String
}
